{
  "name": "react-native-paystack-modal",
  "version": "0.0.1",
  "description": "Paystack payments for React Native and Expo using a WebView popup modal. Fully type-safe with no provider setup required.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-webview": ">=13"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "react-native",
    "expo",
    "paystack",
    "payment",
    "checkout",
    "modal",
    "webview",
    "react-native-paystack"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sonkiee/react-native-paystack-modal.git"
  },
  "homepage": "https://github.com/sonkiee/react-native-paystack-modal",
  "bugs": {
    "url": "https://github.com/sonkiee/react-native-paystack-modal/issues"
  },
  "author": "Kennedy Sunday <annagu.kennedy@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {}
}